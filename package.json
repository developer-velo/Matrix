{
  "name": "matrix",
  "description": "Memory-efficient image to SVG dot-matrix converter.",
  "version": "0.2.0-proto",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "image",
    "matrix",
    "typescript",
    "javascript"
  ],
  "author": {
    "name": "developer-velo",
    "url": "https://github.com/developer-velo"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/developer-velo/matrix.git"
  },
  "funding": {
    "type": "individual",
    "url": "https://github.com/sponsors/developer-velo"
  },
  "files": [
    "output",
    "README.md",
    "LICENSE.md"
  ],
  "exports": {
    ".": {
      "types": "./output/index.d.ts",
      "import": "./output/index.mjs",
      "require": "./output/index.cjs"
    }
  },
  "scripts": {
    "build": "tsc && bun build.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "skia-canvas": "3.0.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "5.9.3"
  },
  "trustedDependencies": [
    "skia-canvas"
  ]
}
