{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],

    "module": "Preserve",
    "moduleResolution": "Bundler",
    "isolatedModules": false,
    "esModuleInterop": true,

    "rootDir": ".",
    "outDir": "output",

    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,

    "strict": true,
    "skipLibCheck": true
   },
   "include": ["index.ts", "matrix.ts"],
   "exclude": ["node_modules", "output"]
}
